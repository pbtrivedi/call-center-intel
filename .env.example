# ── LLM Provider ──────────────────────────────────────────────────────────────
# Active provider: openai | gemini | groq
LLM_PROVIDER=openai

# OpenAI (GPT-4o) — ~$0.03/call
OPENAI_API_KEY=

# Google Gemini 2.0 Flash — 1,500 req/day free
GEMINI_API_KEY=

# Groq Llama 3.3 70B — 30 RPM free
GROQ_API_KEY=

# ── Observability (optional) ───────────────────────────────────────────────────
# LangSmith tracing — leave blank to disable
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=call-center-intel

# ── Audio Processing ───────────────────────────────────────────────────────────
# Whisper model size: tiny | base | large-v3 (large-v3 requires GPU)
WHISPER_MODEL=base

# Upload limits
MAX_FILE_SIZE_MB=50
MAX_DURATION_MINUTES=60

# ── Database ───────────────────────────────────────────────────────────────────
DB_PATH=data/calls.db

# ── Application ────────────────────────────────────────────────────────────────
# Gradio server port
APP_PORT=7860

# Max temp audio files to keep before rolling cleanup
MAX_TEMP_FILES=100
